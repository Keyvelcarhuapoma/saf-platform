# ─── Servidor ───────────────────────────────────────
PORT=3001

# ─── Vectores de Caos (true | false) ────────────────
ENABLE_MEM_LEAK=true
ENABLE_CPU_STRESS=true
ENABLE_NETWORK_DELAY=true

# ─── Tuning: Memory Leak ────────────────────────────
# Tamaño de cada bloque de fuga en bytes (default 96KB)
LEAK_BLOCK_BYTES=98304

# ─── Tuning: CPU Stress ─────────────────────────────
# Iteraciones de pbkdf2Sync por request (default 50k — muy bloqueante)
CPU_PBKDF2_ITERATIONS=50000

# ─── Tuning: Network Delay ──────────────────────────
# Latencia base en ms cuando el sistema está sano
DELAY_BASE_MS=40
# Factor exponencial (cuánto se dispara la curva bajo presión)
DELAY_EXP_FACTOR=0.00010
# Desviación estándar del ruido gaussiano en ms
DELAY_NOISE_STD_DEV=18