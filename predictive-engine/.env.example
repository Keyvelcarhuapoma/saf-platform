# ─── InfluxDB ────────────────────────────────────────
INFLUX_URL=https://us-east-1-1.aws.cloud2.influxdata.com
INFLUX_TOKEN=tu_token_aqui
INFLUX_ORG=saf_org
INFLUX_BUCKET=saf_telemetry

# ─── Motor Predictivo ────────────────────────────────
# Ventana de datos históricos a consultar en minutos
QUERY_WINDOW_MINUTES=30
# Mínimo de puntos requeridos para hacer una predicción válida
MIN_DATA_POINTS=20
# Intervalo del loop de inferencia en segundos
INFERENCE_INTERVAL_SEC=15
# Umbral de TTF en minutos para cambiar el estado a CRITICAL
CRITICAL_TTF_THRESHOLD_MINUTES=10

# ─── API ─────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=info